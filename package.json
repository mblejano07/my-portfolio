{
  "name": "web-app-kit-spa-prime-ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:production": "vue-tsc && vite build --mode production",
    "build:uat": "vue-tsc && vite build --mode uat",
    "build:development": "vue-tsc && vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint --ext .js,.vue,.ts --ignore-path .gitignore --fix src",
    "format": "prettier . --write && npm run lint --fix",
    "prepare": "husky install"
  },
  "dependencies": {
    "@vueuse/core": "^10.7.1",
    "primeicons": "^6.0.1",
    "primevue": "^3.46.0",
    "vue": "^3.3.11",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.8",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "@vitejs/plugin-vue": "^4.5.2",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.19.2",
    "husky": "^8.0.3",
    "postcss": "^8.4.33",
    "prettier": "^3.1.1",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-eslint": "^1.8.1",
    "vue-eslint-parser": "^9.4.0",
    "vue-tsc": "^1.8.27"
  }
}
